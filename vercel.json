{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/faceglow/((?!assets/|favicon.png|og-image.png|placeholder.svg).*)",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/somali-speak-buddy/((?!assets/|favicon.ico|placeholder.svg|robots.txt|sw.js).*)",
      "destination": "/somali-speak-buddy/index.html"
    }
  ]
}