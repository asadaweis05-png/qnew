{
  "rewrites": [
    {
      "source": "/faceglow/assets/:path*",
      "destination": "/faceglow/assets/:path*"
    },
    {
      "source": "/faceglow/:path*",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/somali-speak-buddy/assets/:path*",
      "destination": "/somali-speak-buddy/assets/:path*"
    },
    {
      "source": "/somali-speak-buddy/sw.js",
      "destination": "/somali-speak-buddy/sw.js"
    },
    {
      "source": "/somali-speak-buddy/:path*",
      "destination": "/somali-speak-buddy/index.html"
    },
    {
      "source": "/somali-buddy-speak/:path*",
      "destination": "/somali-speak-buddy/:path*"
    },
    {
      "source": "/somali-buddy/:path*",
      "destination": "/somali-speak-buddy/:path*"
    }
  ]
}