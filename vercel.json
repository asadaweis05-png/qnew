{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/faceglow",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/faceglow/((?!assets/|favicon.png|og-image.png).*)",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/((?!faceglow|admin.html|supabase.js|app.js|index.css|images/|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}