{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/faceglow",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/faceglow/((?!assets/|favicon.png|og-image.png).*)",
      "destination": "/faceglow/index.html"
    },
    {
      "source": "/somali-speak-buddy",
      "destination": "/somali-speak-buddy/index.html"
    },
    {
      "source": "/somali-speak-buddy/((?!assets/|favicon.ico|placeholder.svg|robots.txt|sw.js).*)",
      "destination": "/somali-speak-buddy/index.html"
    },
    {
      "source": "/((?!faceglow|somali-speak-buddy|admin.html|supabase.js|app.js|index.css|images|favicon.ico|assets).*)",
      "destination": "/index.html"
    }
  ]
}